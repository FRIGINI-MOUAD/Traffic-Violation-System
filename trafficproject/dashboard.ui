		<property name="styleSheet">
			<string notr="true">
				/* Main Window */
				QMainWindow {
				background: #f8fafc;
				font-family: 'Segoe UI', Arial, sans-serif;
				}

				/* Sidebar Styling */
				QFrame#sidebar {
				background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
				stop:0 #1e293b, stop:1 #0f172a);
				border: none;
				}

				QPushButton {
				background: transparent;
				color: #cbd5e1;
				border: none;
				border-radius: 8px;
				padding: 12px 15px;
				margin: 4px 8px;
				text-align: left;
				font-size: 14px;
				font-weight: normal;
				}

				QPushButton:hover {
				background: #334155;
				color: #ffffff;
				}

				QPushButton:pressed {
				background: #3b82f6;
				}

				QPushButton[objectName="logoButton"] {
				background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
				stop:0 #3b82f6, stop:1 #1d4ed8);
				color: white;
				font-size: 18px;
				font-weight: bold;
				text-align: center;
				padding: 15px;
				margin: 10px 8px;
				}

				QPushButton[objectName="logoutButton"] {
				background: #dc2626;
				color: white;
				margin-top: auto;
				}

				QPushButton[objectName="logoutButton"]:hover {
				background: #b91c1c;
				}

				/* Remove the overly broad QWidget rule - it was breaking child widgets */
				/* Instead, only style the centralwidget specifically */
				QWidget#centralwidget {
				background: #ffffff;
				}

				QLabel {
				color: #1e293b;
				font-size: 24px;
				font-weight: bold;
				padding: 20px;
				}
			</string>
