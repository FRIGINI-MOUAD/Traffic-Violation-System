  <property name="styleSheet">
   <string notr="true">
				QWidget { background:#f8fafc; font-family:'Segoe UI',Arial,sans-serif; }

				/* Official Police Title - Red Authority */
				QLabel#title {
				color:#1e293b;
				font-size:34px;
				font-weight:bold;
				padding:30px 0;
				background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
				stop:0 #dc2626, stop:1 #ef4444);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				}

				/* Police Action Buttons - Same as PoliceDashboard */
				QPushButton {
				color:white;
				border:none;
				border-radius:12px;
				padding:14px 26px;
				font-weight:bold;
				font-size:15px;
				min-width:160px;
				}

				QPushButton#reviewBtn   { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #f59e0b, stop:1 #d97706); }
				QPushButton#approveBtn  { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #10b981, stop:1 #059669); }
				QPushButton#rejectBtn   { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #ef4444, stop:1 #dc2626); }
				QPushButton#searchBtn   { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #3b82f6, stop:1 #1d4ed8); }

				QPushButton:hover {
				transform: translateY(-3px);
				box-shadow: 0 15px 30px rgba(0,0,0,0.2);
				}

				QLineEdit#searchEdit {
				background:#ffffff;
				border:2px solid #e2e8f0;
				border-radius:12px;
				padding:14px 20px;
				font-size:15px;
				min-height:50px;
				}
				QLineEdit#searchEdit:focus { border-color:#dc2626; }

				QGroupBox {
				background:#ffffff;
				border:3px solid #fee2e2;
				border-radius:20px;
				margin-top:20px;
				padding-top:28px;
				font-weight:bold;
				color:#991b1b;
				box-shadow: 0 15px 35px rgba(220,38,38,0.1);
				}

				QGroupBox::title {
				subcontrol-origin: margin;
				subcontrol-position: top center;
				padding: 0 30px;
				background: #f8fafc;
				color: #dc2626;
				font-size:17px;
				font-weight:bold;
				}

				QTableView {
				background:#ffffff;
				border:2px solid #fee2e2;
				border-radius:16px;
				font-size:15px;
				selection-background-color:#fecaca;
				gridline-color:#fee2e2;
				}

				QHeaderView::section {
				background-color: #f8fafc;
				color: #1e293b;
				padding: 12px 8px;
				font-weight: bold;
				font-size: 14px;
				border: none;
				border-bottom: 2px solid #cbd5e1;
				}

				QLabel#infoLabel {
				color:#991b1b;
				font-size:16px;
				font-weight:600;
				padding:25px;
				background:#fef2f2;
				border-radius:12px;
				border:1px solid #fecaca;
				}
			</string>
