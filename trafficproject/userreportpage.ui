		<property name="styleSheet">
			<string notr="true">
				QWidget { background:#f8fafc; font-family:'Segoe UI',Arial,sans-serif; }

				QLabel#title {
				color:#1e293b;
				font-size:34px;
				font-weight:bold;
				padding:30px 0;
				background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
				stop:0 #3b82f6, stop:1 #6366f1);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				}

				QPushButton {
				color:white; border:none; border-radius:12px;
				padding:14px 24px; font-weight:bold; font-size:15px; min-width:140px;
				}
				QPushButton#createBtn   { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #10b981, stop:1 #059669); }
				QPushButton#updateBtn   { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #3b82f6, stop:1 #1d4ed8); }
				QPushButton#deleteBtn   { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #ef4444, stop:1 #dc2626); }
				QPushButton#searchBtn   { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #f59e0b, stop:1 #d97706); }
				QPushButton:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.15); }

				QLineEdit#searchEdit {
				background:#ffffff; border:2px solid #e2e8f0; border-radius:12px;
				padding:14px 18px; font-size:15px; min-height:48px;
				}
				QLineEdit#searchEdit:focus { border-color:#3b82f6; }

				QGroupBox {
				background:#ffffff; border:2.5px solid #e2e8f0; border-radius:18px;
				margin-top:20px; padding-top:25px; font-weight:bold; color:#475569;
				box-shadow: 0 12px 30px rgba(0,0,0,0.06);
				}
				QGroupBox::title {
				subcontrol-origin: margin; subcontrol-position: top center;
				padding: 0 25px; background: #f8fafc; color: #64748b; font-size:16px;
				}

				QTableView {
				background:#ffffff; border:2px solid #e2e8f0; border-radius:16px;
				font-size:15px; selection-background-color:#dbeafe; gridline-color:#f1f5f9;
				}
				QHeaderView::section {
				background: qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #1e40af, stop:1 #3b82f6);
				color:white; padding:18px; font-weight:bold; font-size:16px;
				border:none; text-transform:uppercase; letter-spacing:1px;
				}

				QLabel#infoLabel {
				color:#64748b; font-size:15px; font-style:italic; padding:20px;
				}
			</string>
		</property>

