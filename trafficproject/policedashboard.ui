   <string notr="true">
				QWidget { background:#f8fafc; font-family:'Segoe UI',Arial,sans-serif; }
				QLabel#titleLabel { color:#1e293b; font-size:28px; font-weight:bold; padding:20px 0px; }
				QPushButton { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #3b82f6, stop:1 #1d4ed8); color:white; border:none; border-radius:8px; padding:10px 15px; font-weight:bold; font-size:14px; min-width:80px; }
				QPushButton:hover { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #2563eb, stop:1 #1e40af); }
				QPushButton#addButton { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #10b981, stop:1 #059669); }
				QPushButton#deleteButton { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #ef4444, stop:1 #dc2626); }
				QPushButton#refreshButton { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #f59e0b, stop:1 #d97706); }
				QLineEdit { background:#fff; border:2px solid #e2e8f0; border-radius:8px; padding:10px 15px; font-size:14px; color:#2d3748; min-height:40px; }
				QLineEdit:focus { border-color:#3b82f6; }
				QLineEdit::placeholder { color:#94a3b8; font-style:italic; }
				QGroupBox { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #fff, stop:1 #f8fafc); border:2px solid #e2e8f0; border-radius:12px; margin-top:10px; padding-top:15px; font-weight:bold; color:#475569; }
				QGroupBox::title { subcontrol-origin:margin; subcontrol-position:top center; padding:0px 10px; background:transparent; color:#64748b; font-size:14px; }
				QLabel#totalLabel, QLabel#pendingLabel, QLabel#paidLabel { color:#3b82f6; font-size:32px; font-weight:bold; text-align:center; }
				QTableView { background:#fff; border:1px solid #e2e8f0; border-radius:8px; }
				QHeaderView::section { background:qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #1e293b, stop:1 #334155); color:white; padding:8px; font-weight:bold; }
