  <property name="styleSheet">
   <string notr="true">
				/* Main Window Styling */
				QMainWindow {
				background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
				stop:0 #1e3c72, stop:0.5 #2a5298, stop:1 #1e3c72);
				border-radius: 12px;
				}

				/* Login Card Styling */
				QFrame#loginCard {
				background: rgba(255, 255, 255, 0.95);
				border-radius: 15px;
				border: 1px solid #e2e8f0;
				padding: 20px;
				}

				/* Label Styling */
				QLabel {
				color: #2d3748;
				font-family: 'Segoe UI', Arial, sans-serif;
				font-size: 14px;
				}

				QLabel[objectName=&quot;titleLabel&quot;] {
				font-size: 24px;
				font-weight: bold;
				color: #1e293b;
				padding: 10px 0px;
				}

				QLabel[objectName=&quot;logoLabel&quot;] {
				background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
				stop:0 #3b82f6, stop:1 #1d4ed8);
				border-radius: 20px;
				font-size: 40px;
				color: white;
				}

				/* Input Field Styling */
				QLineEdit {
				background: #f8fafc;
				border: 2px solid #e2e8f0;
				border-radius: 8px;
				padding: 12px 15px;
				font-size: 14px;
				color: #2d3748;
				font-family: 'Segoe UI', Arial, sans-serif;
				selection-background-color: #3b82f6;
				}

				QLineEdit:focus {
				border-color: #3b82f6;
				background: #ffffff;
				outline: none;
				}

				QLineEdit:placeholder {
				color: #94a3b8;
				font-style: italic;
				}

				/* Button Styling */
				QPushButton {
				background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
				stop:0 #3b82f6, stop:1 #1d4ed8);
				color: white;
				border: none;
				border-radius: 8px;
				padding: 14px;
				font-weight: bold;
				font-size: 14px;
				font-family: 'Segoe UI', Arial, sans-serif;
				}

				QPushButton:hover {
				background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
				stop:0 #2563eb, stop:1 #1e40af);
				}

				QPushButton:pressed {
				background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
				stop:0 #1e40af, stop:1 #1e3a8a);
				}

				/* Tab Widget Styling */
				QTabWidget::pane {
				border: none;
				background: transparent;
				margin-top: 10px;
				}

				QTabWidget::tab-bar {
				alignment: center;
				}

				QTabBar::tab {
				background: transparent;
				color: #64748b;
				padding: 12px 24px;
				margin: 0 2px;
				border-bottom: 3px solid transparent;
				font-weight: bold;
				font-size: 14px;
				min-width: 100px;
				}

				QTabBar::tab:selected {
				color: #3b82f6;
				border-bottom: 3px solid #3b82f6;
				background: rgba(59, 130, 246, 0.1);
				}

				QTabBar::tab:hover:!selected {
				background: rgba(59, 130, 246, 0.05);
				color: #475569;
				}

				/* Link Label Styling */
				QLabel[objectName=&quot;forgotPasswordLabel&quot;] {
				color: #3b82f6;
				font-size: 13px;
				}

				QLabel[objectName=&quot;forgotPasswordLabel&quot;]:hover {
				color: #2563eb;
				text-decoration: underline;
				}

				/* Footer Label */
				QLabel[objectName=&quot;label&quot;] {
				color: #64748b;
				font-size: 12px;
				font-style: italic;
				}
			</string>
